import { Component } from '@angular/core';
import { CommonModule, AsyncPipe } from '@angular/common';
import { FormsModule } from '@angular/forms';
import { RouterLink } from '@angular/router';
import { Observable } from 'rxjs';

import { PostService } from '../../../core/services/post.service';
import { ToastService } from '../../../core/services/toast.service';
import { NavbarComponent } from '../../../shared/navbar/navbar.component';
import { RoleBadgeComponent } from '../../../shared/role-badge/role-badge.component';
import { ParticlesBgComponent } from '../../../shared/particles-bg/particles-bg.component';
import { ToastComponent } from '../../../shared/toast/toast.component';
import { Post } from '../../../core/models/post.model';

@Component({
  selector: 'app-social-feed',
  standalone: true,
  imports: [
    CommonModule,
    AsyncPipe,
    FormsModule,
    RouterLink,
    NavbarComponent,
    RoleBadgeComponent,
    ParticlesBgComponent,
    ToastComponent,
  ],
  template: `
<app-particles-bg />
<app-navbar />
<app-toast />

<div class="page-wrap">
  <!-- LEFT SIDEBAR -->
  <aside class="left-sidebar">
    <div class="card">
      <div class="pm-cover"></div>
      <div class="pm-body">
        <div class="pm-avatar">MJ</div>
        <div class="pm-name">Mohamed Jerbi</div>
        <div class="pm-role"><app-role-badge role="student" /></div>
        <div class="pm-stats">
          <div class="pm-stat"><span class="v">245</span><span class="l">Connexions</span></div>
          <div class="pm-stat"><span class="v">18</span><span class="l">Groupes</span></div>
          <div class="pm-stat"><span class="v">12</span><span class="l">Projets</span></div>
        </div>
      </div>
    </div>
    <div class="card card-body">
      <div class="sec-lbl">Navigation rapide</div>
      <a routerLink="/feed"      class="qlink"><i class="fas fa-home"></i>Fil d'actualité</a>
      <a routerLink="/messaging" class="qlink"><i class="fas fa-comments"></i>Messagerie<span class="cnt">3</span></a>
      <a routerLink="/groups"    class="qlink"><i class="fas fa-users"></i>Mes Groupes</a>
      <a routerLink="/resources" class="qlink"><i class="fas fa-book"></i>Bibliothèque</a>
      <a routerLink="/jobs"      class="qlink"><i class="fas fa-briefcase"></i>Offres & Stages</a>
    </div>
  </aside>

  <!-- MAIN FEED -->
  <main>
    <!-- Stories -->
    <div class="card" style="margin-bottom:1.1rem">
      <div class="stories">
        <div class="story add"><div class="story-ring"><div class="story-inner"><i class="fas fa-plus"></i></div></div><span class="story-name" style="color:var(--gold)">Ma Story</span></div>
        <div class="story" (click)="toast.show('fas fa-circle-notch','Story de Faouzi JAIDI')"><div class="story-ring"><div class="story-inner">FJ</div></div><span class="story-name">F. Jaidi</span></div>
        <div class="story" (click)="toast.show('fas fa-circle-notch','Story de Dhia Abidi')"><div class="story-ring"><div class="story-inner">DA</div></div><span class="story-name">D. Abidi</span></div>
        <div class="story" (click)="toast.show('fas fa-circle-notch','Story de Ahmed Mansour')"><div class="story-ring"><div class="story-inner">AM</div></div><span class="story-name">A. Mansour</span></div>
        <div class="story" (click)="toast.show('fas fa-circle-notch','Story de Leila')"><div class="story-ring"><div class="story-inner">LB</div></div><span class="story-name">L. Ben Salah</span></div>
      </div>
    </div>

    <!-- Composer -->
    <div class="card">
      <div class="composer">
        <div class="composer-row">
          <div class="sm-av">MJ</div>
          <textarea class="composer-input" [(ngModel)]="newPostBody" placeholder="Quoi de neuf Mohamed ?" rows="1"
            (input)="autoResize($event)"></textarea>
        </div>
        <div class="composer-actions">
          <span class="attach-opt" title="Photo"><i class="fas fa-image"></i></span>
          <span class="attach-opt" title="Document"><i class="fas fa-paperclip"></i></span>
          <span class="attach-opt" title="Hashtag"><i class="fas fa-hashtag"></i></span>
          <button class="btn-post" [disabled]="!newPostBody.trim()" (click)="submitPost()">Publier</button>
        </div>
      </div>
    </div>

    <!-- Posts -->
    <ng-container *ngFor="let post of posts$ | async; let i = index">
      <div class="card post-card" [style.animation-delay]="i * 0.08 + 's'">
        <div class="post">
          <div class="post-head">
            <div class="post-av" [style.background]="post.avatarBg" [style.color]="post.avatarColor" routerLink="/profile">{{ post.initials }}</div>
            <div class="post-meta">
              <h4>{{ post.name }} <app-role-badge [role]="post.role" /></h4>
              <div class="post-time"><i class="far fa-clock"></i> {{ post.time }}</div>
            </div>
            <button class="post-more"><i class="fas fa-ellipsis-h"></i></button>
          </div>

          <div class="post-body" [innerHTML]="formatBody(post.body)"></div>

          <div class="post-stats">
            <div class="like-info">
              <span class="like-preview" *ngFor="let av of post.likedBy.slice(0,3)">{{ av }}</span>
              <span class="like-count">{{ post.likes + (post.liked ? 1 : 0) }} j'aime</span>
            </div>
            <div class="comment-toggle" (click)="postSvc.toggleComments(post.id)">
              {{ post.comments.length }} commentaire{{ post.comments.length !== 1 ? 's' : '' }}
            </div>
          </div>

          <div class="action-bar">
            <button class="action-btn" [class.liked]="post.liked" (click)="toggleLike(post)">
              <i class="icon" [class.fas]="post.liked" [class.far]="!post.liked" class="fa-heart"></i> J'aime
            </button>
            <button class="action-btn" (click)="postSvc.toggleComments(post.id)">
              <i class="far fa-comment icon"></i> Commenter
            </button>
            <button class="action-btn" (click)="sharePost(post.id)">
              <i class="fas fa-share icon"></i> Partager
            </button>
          </div>

          <div class="comment-section" [class.open]="post.commentsOpen">
            <div class="comment-input-row">
              <div class="sm-av sm-av-xs">MJ</div>
              <input type="text" class="comment-input" [(ngModel)]="commentInputs[post.id]"
                placeholder="Écrire un commentaire..." (keyup.enter)="submitComment(post.id)">
              <button class="send-btn" (click)="submitComment(post.id)"><i class="fas fa-paper-plane"></i></button>
            </div>
            <div class="comment-list">
              <div class="comment" *ngFor="let c of post.comments">
                <div class="comment-av" [style.background]="c.avatarBg" [style.color]="c.avatarColor">{{ c.initials }}</div>
                <div class="comment-bubble">
                  <div class="auth">{{ c.name }} <app-role-badge [role]="c.role" /></div>
                  <p>{{ c.text }}</p>
                  <div class="comment-actions-row">
                    <button class="c-action" [class.liked-c]="c.liked" (click)="likeComment(c)">
                      <i [class.fas]="c.liked" [class.far]="!c.liked" class="fa-heart"></i> {{ c.likes }}
                    </button>
                    <button class="c-action">Répondre</button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </ng-container>
  </main>

  <!-- RIGHT SIDEBAR -->
  <aside class="right-sidebar">
    <div class="card card-body">
      <div class="widget-title"><i class="fas fa-calendar-alt"></i> Événements</div>
      <div class="event-row" (click)="toast.show('fas fa-calendar-check','Inscription envoyée !')">
        <div class="ev-date"><span class="d">18</span><span class="m">FÉV</span></div>
        <div class="ev-info"><h5>Conférence Sécurité</h5><p>14:00 · Amphi A</p></div>
      </div>
      <div class="event-row" (click)="toast.show('fas fa-calendar-check','Inscription envoyée !')">
        <div class="ev-date"><span class="d">22</span><span class="m">FÉV</span></div>
        <div class="ev-info"><h5>Hackathon ENI</h5><p>09:00 · Campus</p></div>
      </div>
      <div class="event-row" (click)="toast.show('fas fa-calendar-check','Inscription envoyée !')">
        <div class="ev-date"><span class="d">01</span><span class="m">MAR</span></div>
        <div class="ev-info"><h5>Forum Entreprises</h5><p>10:00 · Hall Principal</p></div>
      </div>
    </div>

    <div class="card card-body">
      <div class="widget-title"><i class="fas fa-user-plus"></i> Suggestions</div>
      <div class="suggest-row" *ngFor="let s of suggestions">
        <div class="sm-av sm-av-xs">{{ s.initials }}</div>
        <div class="sug-info"><h5>{{ s.name }}</h5><app-role-badge [role]="s.role" /></div>
        <button class="btn-connect" [class.connected]="s.connected" (click)="connect(s)">
          <i class="fas" [class.fa-plus]="!s.connected" [class.fa-check]="s.connected"></i>
        </button>
      </div>
    </div>

    <div class="card card-body">
      <div class="widget-title"><i class="fas fa-fire"></i> Tendances</div>
      <div class="trend-row" *ngFor="let t of trends" (click)="toast.show('fas fa-hashtag','Exploring '+t.tag)">
        <span class="trend-tag">{{ t.tag }}</span>
        <span class="trend-cnt">{{ t.count }} posts</span>
      </div>
    </div>
  </aside>
</div>
  `,
  styles: [`
    .page-wrap{position:relative;z-index:2;max-width:1280px;margin:0 auto;padding:1.5rem;display:grid;grid-template-columns:270px 1fr 280px;gap:1.25rem;align-items:start;}
    .left-sidebar,.right-sidebar{position:sticky;top:calc(var(--nav-h) + 1rem);}
    .card-body{padding:1.25rem;}
    .pm-cover{height:68px;background:linear-gradient(135deg,#0A1628 0%,#C9A84C 180%);}
    .pm-body{padding:.75rem 1.25rem 1.25rem;margin-top:-28px;text-align:center;}
    .pm-avatar{width:56px;height:56px;border-radius:50%;background:rgba(201,168,76,.15);border:3px solid var(--bg-card);display:inline-flex;align-items:center;justify-content:center;font-size:1.1rem;font-weight:800;color:var(--gold);animation:avatarPulse 3s ease-in-out infinite;margin-bottom:.5rem;}
    .pm-name{font-size:.9rem;font-weight:700;margin-bottom:6px;}
    .pm-role{margin-bottom:.8rem;}
    .pm-stats{display:grid;grid-template-columns:1fr 1fr 1fr;border-top:1px solid var(--border);padding-top:.75rem;margin-top:.75rem;}
    .pm-stat{text-align:center;}.pm-stat+.pm-stat{border-left:1px solid var(--border);}
    .pm-stat .v{display:block;font-weight:800;color:var(--gold);font-size:.95rem;}.pm-stat .l{font-size:.6rem;color:var(--text-3);text-transform:uppercase;}
    .sec-lbl{font-size:.64rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-3);margin-bottom:.7rem;}
    .qlink{display:flex;align-items:center;gap:.7rem;padding:.45rem .6rem;color:var(--text-2);text-decoration:none;border-radius:10px;transition:.2s;font-size:.845rem;}
    .qlink i{color:var(--gold);width:16px;}.qlink:hover{background:rgba(201,168,76,.08);color:var(--gold-light);transform:translateX(4px);}
    .qlink .cnt{margin-left:auto;background:var(--role-admin-bg);color:var(--role-admin);border-radius:20px;padding:1px 7px;font-size:.62rem;font-weight:700;}
    .stories{display:flex;gap:.75rem;overflow-x:auto;padding:.75rem;scrollbar-width:none;}
    .stories::-webkit-scrollbar{display:none;}
    .story{display:flex;flex-direction:column;align-items:center;gap:.4rem;cursor:pointer;flex-shrink:0;transition:.2s;}
    .story:hover{transform:translateY(-3px);}
    .story-ring{width:52px;height:52px;border-radius:50%;padding:2.5px;background:linear-gradient(135deg,var(--gold),var(--gold-light));transition:.3s;}
    .story:hover .story-ring{box-shadow:0 0 14px rgba(201,168,76,.45);}
    .story-inner{width:100%;height:100%;border-radius:50%;background:rgba(201,168,76,.12);border:2px solid var(--bg-card);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.82rem;color:var(--gold);}
    .story.add .story-ring{background:var(--border);padding:1.5px;}
    .story-name{font-size:.62rem;color:var(--text-3);white-space:nowrap;text-align:center;}
    .composer{padding:1rem 1.25rem;}
    .composer-row{display:flex;gap:.85rem;align-items:flex-start;margin-bottom:.85rem;}
    .sm-av{width:40px;height:40px;border-radius:50%;background:rgba(99,102,241,.15);border:2px solid var(--role-student);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.75rem;color:var(--role-student);flex-shrink:0;}
    .sm-av-xs{width:32px!important;height:32px!important;font-size:.68rem!important;}
    .composer-input{flex:1;background:var(--bg-inner);border:1px solid var(--border);padding:.65rem 1.1rem;border-radius:22px;color:var(--text);font-size:.875rem;resize:none;outline:none;transition:.2s;min-height:44px;font-family:'Inter',sans-serif;}
    .composer-input::placeholder{color:var(--text-3);}
    .composer-input:focus{border-color:var(--gold);box-shadow:0 0 0 3px rgba(201,168,76,.1);}
    .composer-actions{display:flex;gap:.5rem;justify-content:flex-end;align-items:center;}
    .attach-opt{color:var(--text-3);cursor:pointer;padding:.4rem .5rem;border-radius:8px;transition:.2s;font-size:.85rem;}
    .attach-opt:hover{color:var(--gold);background:rgba(201,168,76,.08);}
    .btn-post{background:linear-gradient(135deg,var(--gold),var(--gold-light));color:#050D1A;border:none;padding:.55rem 1.35rem;border-radius:22px;font-weight:700;cursor:pointer;font-size:.85rem;transition:.25s;}
    .btn-post:hover:not([disabled]):not(:disabled){transform:scale(1.05);filter:brightness(1.08);}
    .btn-post:disabled{opacity:.4;cursor:not-allowed;}
    .post-card{animation:slideUp .4s ease both;margin-bottom:1.1rem;}
    .post{padding:1.25rem 1.35rem;}
    .post-head{display:flex;gap:.8rem;align-items:flex-start;margin-bottom:1rem;}
    .post-av{width:44px;height:44px;border-radius:50%;border:2px solid var(--border);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.82rem;flex-shrink:0;cursor:pointer;transition:.25s;}
    .post-av:hover{transform:scale(1.1);border-color:var(--gold);}
    .post-meta{flex:1;}
    .post-meta h4{font-size:.9rem;font-weight:700;display:flex;align-items:center;gap:.45rem;flex-wrap:wrap;margin-bottom:3px;}
    .post-time{font-size:.71rem;color:var(--text-3);}
    .post-more{color:var(--text-3);cursor:pointer;padding:.3rem;border-radius:8px;background:none;border:none;font-size:.95rem;transition:.2s;}
    .post-more:hover{color:var(--text);background:var(--bg-inner);}
    .post-body{font-size:.895rem;line-height:1.68;color:var(--text-2);margin-bottom:1rem;}
    .post-stats{display:flex;justify-content:space-between;align-items:center;margin-bottom:.75rem;padding-bottom:.75rem;border-bottom:1px solid var(--border);font-size:.78rem;color:var(--text-3);}
    .like-info{display:flex;align-items:center;gap:.5rem;}
    .like-preview{width:19px;height:19px;border-radius:50%;background:rgba(201,168,76,.15);color:var(--gold);display:inline-flex;align-items:center;justify-content:center;font-size:.55rem;font-weight:700;border:1.5px solid var(--bg-card);}
    .like-count{margin-left:4px;}
    .comment-toggle{cursor:pointer;transition:.2s;}.comment-toggle:hover{color:var(--text);}
    .action-bar{display:flex;gap:.25rem;}
    .action-btn{flex:1;display:flex;align-items:center;justify-content:center;gap:.5rem;padding:.55rem;background:none;border:none;color:var(--text-2);cursor:pointer;border-radius:10px;transition:.25s;font-size:.845rem;font-weight:500;font-family:'Inter',sans-serif;}
    .action-btn:hover{background:var(--bg-inner);}
    .action-btn.liked{color:var(--role-admin);}
    .action-btn.liked .icon{animation:heartBeat .35s ease;}
    .comment-section{display:none;border-top:1px solid var(--border);padding-top:.9rem;margin-top:.75rem;}
    .comment-section.open{display:block;animation:slideUp .25s ease;}
    .comment-input-row{display:flex;gap:.65rem;align-items:center;margin-bottom:.85rem;}
    .comment-input{flex:1;background:var(--bg-inner);border:1px solid var(--border);padding:.55rem 1rem;border-radius:22px;color:var(--text);font-size:.83rem;outline:none;transition:.2s;font-family:'Inter',sans-serif;}
    .comment-input::placeholder{color:var(--text-3);}
    .comment-input:focus{border-color:var(--gold);}
    .send-btn{width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,var(--gold),var(--gold-light));color:#050D1A;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:.25s;flex-shrink:0;font-size:.82rem;}
    .send-btn:hover{transform:scale(1.12) rotate(-5deg);}
    .comment-list{display:flex;flex-direction:column;gap:.7rem;}
    .comment{display:flex;gap:.6rem;}
    .comment-av{width:32px;height:32px;border-radius:50%;border:1.5px solid var(--border);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.7rem;flex-shrink:0;}
    .comment-bubble{background:var(--bg-inner);border-radius:14px;border-top-left-radius:4px;padding:.6rem .9rem;flex:1;}
    .comment-bubble .auth{font-size:.78rem;font-weight:700;margin-bottom:2px;display:flex;align-items:center;gap:.4rem;flex-wrap:wrap;}
    .comment-bubble p{font-size:.82rem;color:var(--text-2);line-height:1.45;}
    .comment-actions-row{display:flex;gap:.75rem;margin-top:.3rem;}
    .c-action{background:none;border:none;font-size:.7rem;color:var(--text-3);cursor:pointer;transition:.2s;font-family:'Inter',sans-serif;}
    .c-action:hover{color:var(--gold);}
    .c-action.liked-c{color:var(--role-admin);}
    .widget-title{font-size:.66rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-3);margin-bottom:.9rem;display:flex;align-items:center;gap:.4rem;}
    .widget-title i{color:var(--gold);}
    .event-row{display:flex;gap:.8rem;margin-bottom:.75rem;align-items:flex-start;cursor:pointer;padding:.5rem;border-radius:10px;transition:.2s;}
    .event-row:hover{background:rgba(201,168,76,.05);}
    .ev-date{width:42px;height:42px;background:rgba(201,168,76,.1);border-radius:10px;display:flex;flex-direction:column;align-items:center;justify-content:center;flex-shrink:0;}
    .ev-date .d{font-weight:800;color:var(--gold);font-size:.95rem;line-height:1;}.ev-date .m{font-size:.5rem;text-transform:uppercase;color:var(--text-3);}
    .ev-info h5{font-size:.82rem;font-weight:600;}.ev-info p{font-size:.7rem;color:var(--text-3);}
    .suggest-row{display:flex;align-items:center;gap:.7rem;margin-bottom:.8rem;}
    .sug-info{flex:1;}.sug-info h5{font-size:.83rem;font-weight:600;margin-bottom:3px;}
    .btn-connect{width:30px;height:30px;border-radius:50%;border:1.5px solid var(--gold);color:var(--gold);background:transparent;cursor:pointer;transition:.2s;display:flex;align-items:center;justify-content:center;font-size:.78rem;}
    .btn-connect:hover{background:var(--gold);color:#050D1A;}
    .btn-connect.connected{background:var(--gold);color:#050D1A;}
    .trend-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:.75rem;cursor:pointer;padding:.3rem .4rem;border-radius:8px;transition:.2s;}
    .trend-row:hover{background:rgba(201,168,76,.06);}
    .trend-tag{font-size:.82rem;font-weight:700;color:var(--gold);}
    .trend-cnt{font-size:.7rem;color:var(--text-3);}
  `]
})
export class SocialFeedComponent {
  posts$: Observable<Post[]>;

  constructor(
    public postSvc: PostService,
    public toast: ToastService
  ) {
    this.posts$ = this.postSvc.posts$;
  }

  newPostBody = '';
  commentInputs: Record<number, string> = {};

  suggestions = [
    { initials: 'AM', name: 'Ahmed Mansour', role: 'student' as const, connected: false },
    { initials: 'SR', name: 'Sonia Rahmani', role: 'prof' as const, connected: false },
    { initials: 'KM', name: 'Karim Mejri', role: 'alumni' as const, connected: false },
  ];

  trends = [
    { tag: '#Cybersécurité', count: 42 },
    { tag: '#PFE2026', count: 28 },
    { tag: '#Angular', count: 19 },
    { tag: '#ENICAR', count: 55 },
  ];

  submitPost(): void {
    if (!this.newPostBody.trim()) return;
    this.postSvc.addPost(this.newPostBody.trim());
    this.newPostBody = '';
    this.toast.show('fas fa-check-circle', 'Publication partagée !');
  }

  toggleLike(post: Post): void {
    this.postSvc.toggleLike(post.id);
    if (!post.liked) this.toast.show('fas fa-heart', 'Publication aimée !');
  }

  submitComment(postId: number): void {
    const text = (this.commentInputs[postId] || '').trim();
    if (!text) return;
    this.postSvc.addComment(postId, text);
    this.commentInputs[postId] = '';
    this.toast.show('fas fa-check-circle', 'Commentaire publié !');
  }

  likeComment(c: { liked: boolean; likes: number }): void {
    c.liked = !c.liked;
    c.likes += c.liked ? 1 : -1;
  }

  sharePost(postId: number): void {
    navigator.clipboard?.writeText(`https://enicar.connect/post/${postId}`).catch(() => { });
    this.toast.show('fas fa-link', 'Lien copié dans le presse-papier !');
  }

  connect(s: { connected: boolean; name: string }): void {
    s.connected = !s.connected;
    this.toast.show(
      s.connected ? 'fas fa-user-check' : 'fas fa-user-minus',
      s.connected ? 'Demande envoyée !' : 'Connexion retirée.'
    );
  }

  formatBody(text: string): string {
    return text
      .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
      .replace(/#(\w+)/g, '<span style="color:var(--gold);font-weight:600;cursor:pointer">#$1</span>')
      .replace(/\n/g, '<br>');
  }

  autoResize(event: Event): void {
    const el = event.target as HTMLTextAreaElement;
    el.style.height = 'auto';
    el.style.height = el.scrollHeight + 'px';
  }
}
